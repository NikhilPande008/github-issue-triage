+    def test_http_302_doesnt_change_query_to_get(self, httpbin):
+        session = RedirectSession([302])
+        request = requests.Request("QUERY", httpbin("query")).prepare()
+        response = session.send(request)
+
+        redirected = next(session.resolve_redirects(response, request))
+
+        assert redirected.request.method == "QUERY"
