+def test_create_default_tool_context_preserves_litellm_proxy_configuration(
+    monkeypatch: pytest.MonkeyPatch,
+) -> None:
+    """Tool guardrail client should receive LiteLLM proxy settings."""
+    openai_mod = types.ModuleType("openai")
+
+    class StubAsyncOpenAI:
+        def __init__(self, **kwargs: Any) -> None:
+            self.kwargs = kwargs
+
+    openai_mod.AsyncOpenAI = StubAsyncOpenAI
+    monkeypatch.setitem(sys.modules, "openai", openai_mod)
+
+    context = agents._create_default_tool_context(
+        api_key="litellm-proxy-key",
+        base_url="http://litellm-proxy.example/v1",
+    )
+
+    assert context.guardrail_llm.kwargs == {  # type: ignore[attr-defined]  # noqa: S101
+        "api_key": "litellm-proxy-key",
+        "base_url": "http://litellm-proxy.example/v1",
+    }
+
+
